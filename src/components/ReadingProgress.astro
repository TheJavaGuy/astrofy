---
// Top-of-viewport reading progress bar. Updates --progress on its element
// via a passive scroll listener; obeys prefers-reduced-motion by clamping
// the transition (see global.css).
---

<div
  class="reading-progress no-print"
  role="presentation"
  aria-hidden="true"
  id="reading-progress"
>
</div>

<script>
  function setup() {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;
    const update = () => {
      const doc = document.documentElement;
      const scrolled = doc.scrollTop;
      const max = doc.scrollHeight - doc.clientHeight;
      const pct = max <= 0 ? 0 : Math.min(1, Math.max(0, scrolled / max));
      bar.style.setProperty('--progress', String(pct));
    };
    update();
    document.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  }
  setup();
  document.addEventListener('astro:page-load', setup);
</script>
