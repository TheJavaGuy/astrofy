---
import { Icon } from 'astro-iconset/components';

const social = [
  {
    href: 'https://github.com/manuelernestog',
    icon: 'mdi:github',
    label: 'GitHub',
  },
  {
    href: 'https://www.linkedin.com/in/manuelernestogr',
    icon: 'mdi:linkedin',
    label: 'LinkedIn',
  },
  {
    href: 'https://twitter.com/manuelernestog',
    icon: 'mdi:twitter',
    label: 'Twitter',
  },
  {
    href: '/rss.xml',
    icon: 'mdi:rss',
    label: 'RSS Feed',
  },
  {
    href: 'https://manuelernestog.github.io/support-my-work',
    icon: 'mdi:heart-outline',
    label: 'Support my work',
  },
];
---

<div class="mt-auto px-4 pt-6 pb-2 border-t border-base-300/70">
  <ul class="flex items-center justify-between gap-1">
    {
      social.map((s) => (
        <li>
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-9 h-9 rounded-full text-secondary hover:text-primary hover:bg-base-200 transition-colors duration-200"
            aria-label={s.label}
            title={s.label}
          >
            <Icon name={s.icon} size={18} aria-hidden="true" />
          </a>
        </li>
      ))
    }
  </ul>
</div>
