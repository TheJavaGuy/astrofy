---
const today = new Date();
---

<footer
  class="mt-16 border-t border-base-300/70 pt-8 pb-10 text-sm text-secondary"
>
  <div
    class="max-w-[1100px] mx-auto px-5 md:px-8 flex flex-col sm:flex-row items-center justify-between gap-2"
  >
    <p>&copy; {today.getFullYear()} Manuel Ernesto</p>
    <p class="opacity-80">
      Built with <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium hover:text-primary transition-colors">Astro</a
      >
      ·
      <a
        href="https://astrofy-template.netlify.app/"
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium hover:text-primary transition-colors"
        >Astrofy</a
      >
    </p>
  </div>
</footer>
