---
import { Image } from 'astro:assets';
import Tag from './Tag.astro';

interface Props {
  title: string;
  img?: string;
  desc?: string;
  url: string;
  badge?: string;
  tags?: string[];
  target?: string;
}

const {
  title,
  img,
  desc,
  url,
  badge,
  tags,
  target = '_blank',
} = Astro.props;
---

<article
  class="card-hover group flex flex-col rounded-2xl border border-base-300/80 bg-base-100/70 overflow-hidden h-full"
  data-reveal
>
  <a
    href={url}
    target={target}
    rel={target === '_blank' ? 'noopener noreferrer' : undefined}
    class="flex flex-col h-full"
  >
    {
      img && (
        <div class="relative aspect-video overflow-hidden bg-base-200">
          <Image
            width={750}
            height={422}
            format="webp"
            src={img}
            alt={title}
            class="card-image absolute inset-0 w-full h-full object-cover"
          />
        </div>
      )
    }
    <div class="flex flex-col gap-2 p-5 flex-1">
      <div class="flex items-start justify-between gap-3">
        <h3
          class="font-display text-lg font-semibold leading-snug text-base-content group-hover:text-primary transition-colors"
        >
          {title}
        </h3>
        {badge && <span class="badge-soft shrink-0">{badge}</span>}
      </div>
      {desc && <p class="text-sm text-secondary line-clamp-3">{desc}</p>}
      {
        tags && tags.length > 0 && (
          <div class="mt-auto flex flex-wrap gap-1.5 pt-3">
            {tags.map((tag) => (
              <Tag label={tag} />
            ))}
          </div>
        )
      }
    </div>
  </a>
</article>
