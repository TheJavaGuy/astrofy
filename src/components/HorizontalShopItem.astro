---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  img?: string;
  desc?: string;
  url: string;
  badge?: string;
  pricing?: string;
  oldPricing?: string;
  checkoutUrl?: string;
  details?: boolean;
  custom_link?: boolean | string;
  custom_link_label?: string;
}

const {
  title,
  img,
  desc,
  url,
  badge,
  pricing,
  oldPricing,
  checkoutUrl,
  details = true,
  custom_link = false,
  custom_link_label = '',
} = Astro.props;
---

<article
  class="card-hover group relative rounded-2xl border border-base-300/80 bg-base-100/70 overflow-hidden"
  data-reveal
>
  <div class="flex flex-col md:flex-row gap-5 md:gap-7 p-4 md:p-5">
    <a
      href={url}
      class="relative shrink-0 overflow-hidden rounded-xl bg-base-200 md:w-56 aspect-video md:aspect-[4/3] ring-1 ring-base-300/60 block"
    >
      {
        img && (
          <Image
            width={750}
            height={422}
            format="webp"
            src={img}
            alt={title}
            class="card-image absolute inset-0 w-full h-full object-cover"
          />
        )
      }
    </a>
    <div class="flex flex-col gap-3 min-w-0 flex-1">
      <div class="flex items-start justify-between gap-3">
        <a href={url} class="flex-1 min-w-0">
          <h3
            class="font-display text-xl md:text-2xl font-semibold leading-snug text-base-content group-hover:text-primary transition-colors"
          >
            {title}
          </h3>
        </a>
        {badge && <span class="badge-soft shrink-0">{badge}</span>}
      </div>
      <div class="flex items-baseline gap-2 font-display">
        <span class="text-2xl md:text-3xl font-semibold tabular-nums"
          >{pricing}</span
        >
        {
          oldPricing && (
            <span class="text-base text-secondary line-through tabular-nums">
              {oldPricing}
            </span>
          )
        }
      </div>
      {details && desc && <p class="text-sm text-secondary line-clamp-3">{desc}</p>}
      <div class="mt-auto flex flex-wrap gap-2 pt-1">
        {
          custom_link && custom_link_label && typeof custom_link === 'string' && (
            <a
              href={custom_link}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline rounded-full"
            >
              {custom_link_label}
            </a>
          )
        }
        {
          checkoutUrl && (
            <a
              href={checkoutUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-primary rounded-full"
            >
              Buy now
            </a>
          )
        }
      </div>
    </div>
  </div>
</article>
