---
import { Icon } from 'astro-iconset/components';
---

<header
  class="sticky lg:hidden top-0 z-30 flex h-14 w-full items-center bg-base-100/85 backdrop-blur-md border-b border-base-300/70 transition-all duration-200 text-base-content"
>
  <div class="flex items-center justify-between w-full px-4">
    <label
      for="my-drawer"
      class="inline-flex items-center justify-center w-10 h-10 rounded-lg hover:bg-base-200 transition-colors cursor-pointer"
      aria-label="Open menu"
    >
      <Icon name="mdi:menu" size={22} aria-hidden="true" />
    </label>
    <a
      href="/"
      class="font-display text-lg font-semibold tracking-tight"
    >
      Manuel Ernesto
    </a>
    <span class="w-10" aria-hidden="true"></span>
  </div>
</header>
