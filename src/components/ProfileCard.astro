---
import { Image } from 'astro:assets';

interface Props {
  name?: string;
  role?: string;
  status?: string;
}

const {
  name = 'Manuel Ernesto',
  role = 'Software Engineer',
  status = 'Available for work',
} = Astro.props;
---

<a
  href="/"
  class="group flex flex-col items-center text-center mt-5 mb-5 px-2"
  aria-label={`${name} — home`}
>
  <div class="relative">
    <span
      class="absolute -inset-1.5 rounded-full bg-primary/20 blur-xl opacity-60 group-hover:opacity-90 transition-opacity duration-500"
      aria-hidden="true"
    >
    </span>
    <span
      class="relative block rounded-full ring-1 ring-base-300 overflow-hidden bg-base-100"
    >
      <Image
        class="block w-24 h-24 object-cover"
        format="webp"
        width={300}
        height={300}
        src="/profile.webp"
        alt={`Portrait of ${name}`}
      />
    </span>
  </div>
  <span class="mt-4 font-display text-lg font-semibold leading-tight">
    {name}
  </span>
  <span class="mt-0.5 text-xs text-secondary">{role}</span>
  {
    status && (
      <span class="mt-3 inline-flex items-center gap-1.5 text-[0.65rem] font-medium uppercase tracking-wider text-success">
        <span
          class="block w-1.5 h-1.5 rounded-full bg-success shadow-[0_0_0_3px_color-mix(in_oklch,var(--color-success)_25%,transparent)]"
        />
        {status}
      </span>
    )
  }
</a>
