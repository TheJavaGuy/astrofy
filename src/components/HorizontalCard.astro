---
import { Image } from 'astro:assets';
import Tag from './Tag.astro';

interface Props {
  title: string;
  img?: string;
  desc?: string;
  url: string;
  badge?: string;
  tags?: string[];
  target?: string;
}

const {
  title,
  img,
  desc,
  url,
  badge,
  tags,
  target = '_blank',
} = Astro.props;

const tagBase = url.includes('/')
  ? url.split('/').slice(0, -1).join('/') + '/tag'
  : '/tag';
---

<article
  class="card-hover group relative flex flex-col md:flex-row gap-5 md:gap-7 p-4 md:p-5 rounded-2xl border border-base-300/80 bg-base-100/70 overflow-hidden"
  data-reveal
>
  {
    img && (
      <a
        href={url}
        target={target}
        rel={target === '_blank' ? 'noopener noreferrer' : undefined}
        class="relative shrink-0 overflow-hidden rounded-xl bg-base-200 md:w-56 aspect-video md:aspect-[4/3] ring-1 ring-base-300/60 block z-[1]"
        tabindex="-1"
        aria-hidden="true"
      >
        <Image
          src={img}
          width={750}
          height={422}
          format="webp"
          alt=""
          class="card-image absolute inset-0 w-full h-full object-cover"
        />
      </a>
    )
  }
  <div class="flex flex-col gap-2 min-w-0 flex-1 relative">
    <div class="flex items-start justify-between gap-3">
      <h3
        class="font-display text-xl md:text-2xl font-semibold leading-snug text-base-content group-hover:text-primary transition-colors"
      >
        <a
          href={url}
          target={target}
          rel={target === '_blank' ? 'noopener noreferrer' : undefined}
          class="before:absolute before:inset-0 before:rounded-2xl before:content-['']"
        >
          {title}
        </a>
      </h3>
      {badge && <span class="badge-soft shrink-0 relative z-[2]">{badge}</span>}
    </div>
    {desc && <p class="text-sm md:text-base text-secondary line-clamp-2">{desc}</p>}
    {
      tags && tags.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-1.5 pt-2 relative z-[2]">
          {tags.map((tag) => (
            <Tag label={tag} href={`${tagBase}/${tag}`} />
          ))}
        </div>
      )
    }
  </div>
</article>
