---
import SideBarMenuItem from './SideBarMenuItem.astro';
const { sideBarActiveItemID } = Astro.props;
const isActive = (id: string) => id === sideBarActiveItemID;
---

<ul class="menu grow shrink menu-md overflow-y-auto">
  <SideBarMenuItem id="home" href="/" label="Home Ivan" active={isActive('home')} />
  <SideBarMenuItem id="projects" href="/projects" label="Projects" active={isActive('projects')} />
  <SideBarMenuItem id="services" href="/services" label="Services" active={isActive('services')} />
  <SideBarMenuItem id="store" href="/store" label="Store" active={isActive('store')} />
  <SideBarMenuItem id="blog" href="/blog/" label="Blog" active={isActive('blog')} />
  <SideBarMenuItem id="cv" href="/cv" label="CV" active={isActive('cv')} />
  <SideBarMenuItem
    href="mailto:contact.manuelernestog@gmail.com"
    label="Contact"
    external
  />
</ul>
