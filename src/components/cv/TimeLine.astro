---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="flex">
  <div class="education__time shrink-0 mt-1.5 relative">
    <span
      class="block w-3 h-3 rounded-full bg-primary ring-4 ring-primary/15 shadow-[0_0_0_4px_var(--color-base-100)]"
    >
    </span>
    <span
      class="education__line block w-px h-full mt-1 translate-x-[5.5px] bg-gradient-to-b from-base-300 via-base-300 to-transparent"
    >
    </span>
  </div>
  <div class="experience__data pl-5 pb-8 flex-1">
    <h3 class="font-display font-semibold text-lg mb-1 leading-snug">{title}</h3>
    <span class="block text-xs text-secondary mb-2 tracking-wide">{subtitle}</span>
    <div class="text-sm md:text-[0.9375rem] text-base-content/85 leading-relaxed">
      <slot />
    </div>
  </div>
</div>
