---
interface Props {
  prev?: string;
  next?: string;
  prevLabel?: string;
  nextLabel?: string;
}

const {
  prev,
  next,
  prevLabel = 'Newer',
  nextLabel = 'Older',
} = Astro.props;
---

<nav
  class="mt-12 pt-6 border-t border-base-300/70 flex items-center justify-between gap-3"
  aria-label="Pagination"
>
  {
    prev ? (
      <a
        href={prev}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-base-300/80 text-sm font-medium hover:border-primary hover:text-primary transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="14"
          height="14"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        {prevLabel}
      </a>
    ) : (
      <span />
    )
  }
  {
    next ? (
      <a
        href={next}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-base-300/80 text-sm font-medium hover:border-primary hover:text-primary transition-colors"
      >
        {nextLabel}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="14"
          height="14"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
    ) : (
      <span />
    )
  }
</nav>
