---
import { type StoreSchema } from '../content.config';
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';

export interface Props extends StoreSchema {}

const {
  title,
  description,
  heroImage,
  pricing,
  oldPricing,
  checkoutUrl,
  badge,
  custom_link,
  custom_link_label,
} = Astro.props;
---

<BaseLayout title={title} description={description} image={heroImage}>
  <article class="relative mx-auto max-w-[820px]">
    <header class="mb-8" data-reveal>
      <a
        href="/store/"
        class="inline-flex items-center gap-1 mb-5 text-sm text-secondary hover:text-primary transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="14"
          height="14"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Store
      </a>

      <div class="flex items-start justify-between gap-4 mb-4">
        <h1
          class="font-display text-4xl md:text-5xl font-bold leading-[1.08] tracking-tight"
        >
          {title}
        </h1>
        {badge && <span class="badge-soft shrink-0 mt-2">{badge}</span>}
      </div>
      {description && <p class="text-lg text-secondary max-w-[60ch]">{description}</p>}
    </header>

    {
      heroImage && (
        <figure
          class="relative mb-10 overflow-hidden rounded-2xl ring-1 ring-base-300/70 shadow-soft-md"
          data-reveal
        >
          <Image
            width={1500}
            height={844}
            format="webp"
            src={heroImage}
            alt={title}
            class="w-full h-auto"
          />
        </figure>
      )
    }

    <div
      class="surface rounded-2xl p-5 md:p-6 mb-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4"
      data-reveal
    >
      <div class="flex items-baseline gap-3 font-display">
        <span class="text-3xl md:text-4xl font-semibold tabular-nums"
          >{pricing}</span
        >
        {
          oldPricing && (
            <span class="text-lg text-secondary line-through tabular-nums">
              {oldPricing}
            </span>
          )
        }
      </div>
      <div class="flex flex-wrap gap-2">
        {
          custom_link && (
            <a
              class="btn btn-outline rounded-full"
              href={custom_link}
              target="_blank"
              rel="noopener noreferrer"
            >
              {custom_link_label}
            </a>
          )
        }
        {
          checkoutUrl && (
            <a
              class="btn btn-primary rounded-full"
              href={checkoutUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Buy now
            </a>
          )
        }
      </div>
    </div>

    <div class="prose md:prose-lg mx-auto" data-reveal>
      <slot />
    </div>
  </article>
</BaseLayout>
