---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Not Found" includeSidebar={false}>
  <section
    class="relative isolate min-h-[70vh] flex flex-col items-center justify-center text-center px-4"
  >
    <span class="hero-blob -top-20 left-1/2 -translate-x-1/2" aria-hidden="true"
    ></span>
    <span class="eyebrow mb-4" data-reveal>Error</span>
    <h1
      class="font-display text-[clamp(7rem,18vw,12rem)] font-bold leading-none tracking-tighter text-primary"
      data-reveal
    >
      404
    </h1>
    <h2
      class="font-display text-2xl md:text-3xl font-semibold mt-6 mb-3"
      data-reveal
    >
      Page not found
    </h2>
    <p class="text-secondary max-w-[40ch] mb-8" data-reveal>
      The page you're looking for either moved, was renamed, or never existed.
    </p>
    <a
      href="/"
      class="btn btn-primary rounded-full px-6 shadow-soft-sm"
      data-reveal
    >
      Back to home
    </a>
  </section>
</BaseLayout>
