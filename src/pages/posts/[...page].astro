---
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HorizontalCard from '../../components/HorizontalCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { postHref } from '../../lib/routes';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection('blog');
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<CollectionEntry<'blog'>> };
---

<BaseLayout title="Blog" sideBarActiveItemID="blog">
  <header class="pt-4 pb-8" data-reveal>
    <span class="eyebrow">Writing</span>
    <h1
      class="font-display text-4xl md:text-5xl font-bold tracking-tight mt-2 leading-[1.08]"
    >
      Blog
    </h1>
    <p class="mt-3 text-secondary max-w-[60ch]">
      Notes on software, the craft of building things, and the messy middle of
      running a small business.
    </p>
  </header>

  {
    page.data.length === 0 ? (
      <div class="surface rounded-2xl p-6 border-l-4 border-l-primary">
        <p class="font-display font-semibold text-lg">Nothing here yet</p>
        <p class="text-secondary mt-1">
          There are no blog posts at the moment. Check back later.
        </p>
      </div>
    ) : (
      <div class="flex flex-col gap-4">
        {page.data.map((post) => (
          <HorizontalCard
            title={post.data.title}
            img={post.data.heroImage}
            desc={post.data.description}
            url={postHref(post.id)}
            target="_self"
            badge={post.data.badge}
            tags={post.data.tags}
          />
        ))}
      </div>
    )
  }

  <Pagination
    prev={page.url.prev}
    next={page.url.next}
    prevLabel="Recent posts"
    nextLabel="Older posts"
  />
</BaseLayout>
