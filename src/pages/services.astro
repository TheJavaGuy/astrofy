---
import BaseLayout from '../layouts/BaseLayout.astro';
import HorizontalCard from '../components/HorizontalCard.astro';

const services = [
  {
    title: 'Service 1',
    img: '/post_img.webp',
    desc: 'Describe what this service delivers, who it is for, and how it works.',
    url: '#',
    badge: 'New',
  },
  {
    title: 'Service 2',
    img: '/post_img.webp',
    desc: 'Describe what this service delivers, who it is for, and how it works.',
    url: '#',
  },
  {
    title: 'Service 3',
    img: '/post_img.webp',
    desc: 'Describe what this service delivers, who it is for, and how it works.',
    url: '#',
    badge: 'New',
  },
  {
    title: 'Service 4',
    img: '/post_img.webp',
    desc: 'Describe what this service delivers, who it is for, and how it works.',
    url: '#',
  },
];
---

<BaseLayout title="Services" sideBarActiveItemID="services">
  <header class="pt-4 pb-8" data-reveal>
    <span class="eyebrow">What I offer</span>
    <h1
      class="font-display text-4xl md:text-5xl font-bold tracking-tight mt-2 leading-[1.08]"
    >
      Services
    </h1>
    <p class="mt-3 text-secondary max-w-[60ch]">
      Engagements I'm open to. Reach out if any of these fit what you're trying
      to build.
    </p>
  </header>

  <div class="flex flex-col gap-4">
    {services.map((s) => <HorizontalCard {...s} />)}
  </div>
</BaseLayout>
