---
import BaseLayout from '../layouts/BaseLayout.astro';
import HorizontalCard from '../components/HorizontalCard.astro';

const projects = [
  {
    title: 'Demo Project 1',
    img: '/post_img.webp',
    desc: 'Short summary of the project — problem, stack, outcome. Replace with real content.',
    url: '#',
    badge: 'New',
  },
  {
    title: 'Demo Project 2',
    img: '/post_img.webp',
    desc: 'Short summary of the project — problem, stack, outcome. Replace with real content.',
    url: '#',
  },
  {
    title: 'Demo Project 3',
    img: '/post_img.webp',
    desc: 'Short summary of the project — problem, stack, outcome. Replace with real content.',
    url: '#',
    badge: 'FOSS',
  },
  {
    title: 'Demo Project 4',
    img: '/post_img.webp',
    desc: 'Short summary of the project — problem, stack, outcome. Replace with real content.',
    url: '#',
  },
  {
    title: 'Demo Project 5',
    img: '/post_img.webp',
    desc: 'Short summary of the project — problem, stack, outcome. Replace with real content.',
    url: '#',
  },
];
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <header class="pt-4 pb-8" data-reveal>
    <span class="eyebrow">Portfolio</span>
    <h1
      class="font-display text-4xl md:text-5xl font-bold tracking-tight mt-2 leading-[1.08]"
    >
      Projects
    </h1>
    <p class="mt-3 text-secondary max-w-[60ch]">
      A selection of things I've built — products, open-source work, and
      experiments worth keeping around.
    </p>
  </header>

  <div class="flex flex-col gap-4">
    {projects.map((p) => <HorizontalCard {...p} />)}
  </div>
</BaseLayout>
